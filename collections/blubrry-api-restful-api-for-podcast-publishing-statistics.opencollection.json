          "http": {
            "method": "GET",
            "url": "https://api.blubrry.com/2/media/:keyword/migrate_status.json",
            "params": [
              {
                "name": "keyword",
                "value": "",
                "type": "path",
                "description": "Program keyword that identifies the show."
              }
            ]
          },
          "docs": "Get migration status"
        }
      ]
