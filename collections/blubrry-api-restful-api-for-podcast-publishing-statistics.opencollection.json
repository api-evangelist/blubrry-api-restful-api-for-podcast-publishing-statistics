              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "source_url",
                  "value": ""
                }
              ]
            }
          },
          "docs": "Queue a media file for migration into Blubrry hosting"
        },
        {
          "info": {
            "name": "Remove a migration request",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.blubrry.com/2/media/:keyword/migrate_remove.json",
